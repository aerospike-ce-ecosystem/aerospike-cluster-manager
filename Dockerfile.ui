# =============================================================================
# UI (Next.js 14 standalone) — port 3100
# =============================================================================
FROM node:22-alpine AS deps
WORKDIR /app
COPY ui/package.json ui/package-lock.json ./
RUN npm ci --legacy-peer-deps

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY ui/ .
# /api/* is proxied to API_URL at runtime by the custom server.js, so no
# build-time API_URL is needed (and would silently override the runtime env).
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# =============================================================================
# Runtime
# =============================================================================
FROM node:22-alpine AS runtime

RUN apk add --no-cache curl \
    && addgroup -g 1001 -S appuser \
    && adduser -u 1001 -S appuser -G appuser

WORKDIR /app

COPY --from=builder --chown=appuser:appuser /app/public ./public
COPY --from=builder --chown=appuser:appuser /app/.next/standalone ./
COPY --from=builder --chown=appuser:appuser /app/.next/static ./.next/static
# Sidecar proxy: spawns the standalone-generated ./server.js as a child on an
# internal loopback port and forwards /api/* to API_URL (resolved at
# container start) while passing everything else (including /_next/static and
# /public assets) through unchanged. Keeps Next.js's static-routing untouched.
COPY --from=builder --chown=appuser:appuser /app/proxy.js ./proxy.js

USER appuser

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3100

EXPOSE 3100

HEALTHCHECK --interval=10s --timeout=5s --retries=3 --start-period=15s \
    CMD curl -f http://localhost:3100/ || exit 1

CMD ["node", "proxy.js"]
